[global]
ioengine=libaio
direct=1
runtime=60
time_based

[seq-1m-q8t1-readwrite]
bs=1m
iodepth=8
numjobs=1
readwrite=readwrite
rwmixread=50
stonewall

[seq-128k-q32t1-readwrite]
bs=128k
iodepth=32
numjobs=1
readwrite=readwrite
rwmixread=50
stonewall

[rand-4k-q32t16-readwrite]
bs=4k
iodepth=32
numjobs=16
readwrite=readwrite
rwmixread=50
stonewall

[rand-4k-q1t1-readwrite]
bs=4k
iodepth=1
numjobs=1
readwrite=readwrite
rwmixread=50
stonewall
